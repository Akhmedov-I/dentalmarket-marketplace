# =============================================================================
# DentalMarket – Environment Variables
# Copy this file:  cp .env.example .env   then fill in production values.
# =============================================================================

# --- Database (PostgreSQL) ---------------------------------------------------
DATABASE_URL=postgresql://dentalmarket:dentalmarket_dev@localhost:5432/dentalmarket

# --- Cache / Sessions (Redis) ------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- Search Engine (OpenSearch) ----------------------------------------------
OPENSEARCH_URL=http://localhost:9200

# --- Message Broker (RabbitMQ) -----------------------------------------------
RABBITMQ_URL=amqp://dentalmarket:dentalmarket_dev@localhost:5672

# --- Analytics (ClickHouse) --------------------------------------------------
CLICKHOUSE_URL=http://dentalmarket:dentalmarket_dev@localhost:8123/dentalmarket_analytics

# --- Auth / JWT --------------------------------------------------------------
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# --- Email (SMTP) ------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# --- Object Storage (S3-compatible) ------------------------------------------
S3_ENDPOINT=
S3_BUCKET=dentalmarket
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Application -------------------------------------------------------------
NODE_ENV=development
PORT=3000
